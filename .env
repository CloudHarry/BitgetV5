# Kredensial API Bitget (JANGAN commit file .env asli ke git!)
BITGET_API_KEY=....
BITGET_API_SECRET=....
BITGET_API_PASSWORD=....

# Pengaturan strategi MTF SMC
TIMEFRAME=1h
LIMIT=100
INTERVAL_MINUTES=15
POSITION_CHECK_SECONDS=10

# Nominal Margin & Leverage V3
USDT_AMOUNT=1.5
LEVERAGE=10

# Fitur Pengunci Modal otomatis ala SMC (Break Even)
USE_BREAK_EVEN=true

# Pengaturan V2 (Akan otomatis diabaikan oleh Engine V3, biarkan saja)
TRAILING_PERCENT=1.0
TP_PERCENT=2.5
THRESHOLD_MIN=70
WIN_PROB_MIN=80

# Risk management (TripWire)
MAX_HOLD_MINUTES=240
DAILY_LOSS_LIMIT_USDT=-10

# Trade journal (histori entry/close disimpan ke CSV ini)
JOURNAL_PATH=trades_journal.csv

# WAJIB true dulu sampai kamu yakin bot berjalan benar di paper/testnet.
DRY_RUN=true
